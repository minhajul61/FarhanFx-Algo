//@version=5
// FarhanFX — Individual Strategy Tester
// প্রতিটা strategy আলাদা আলাদা test করো
// Settings > strat_type dropdown change করে দেখো কোনটার WR বেশি
strategy("FarhanFX Strategy Tester", overlay=true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 1,
     initial_capital   = 10000,
     commission_type   = strategy.commission.cash_per_contract,
     commission_value  = 0.70,
     slippage          = 3)

// ── কোন strategy test করবে ───────────────────────────────────────────────────
strat = input.string("M2B_M2S",   "Strategy to Test",
     options=["M2B_M2S", "Pin_Bar_EMA", "IB_FBO", "Engulfing_Trend", "3Bar_Reversal", "Supertrend_Only", "All_Combined"])

// ── SL / TP ───────────────────────────────────────────────────────────────────
sl_atr  = input.float(1.5, "SL × ATR",  group="Trade")
tp_atr  = input.float(3.0, "TP × ATR",  group="Trade")
req_d1  = input.bool(true,  "D1 Trend must align",    group="Filters")
req_h4  = input.bool(true,  "H4 Trend must align",    group="Filters")
sess_f  = input.bool(true,  "London+NY session only", group="Filters")

// ── INDICATORS ────────────────────────────────────────────────────────────────
atr14  = ta.atr(14)
ema20  = ta.ema(close, 20)
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi14  = ta.rsi(close, 14)
[_, _, macd_h] = ta.macd(close, 12, 26, 9)
[st_line, st_dir] = ta.supertrend(3.0, 10)
pip = syminfo.mintick * 10

// ── D1 + H4 Trend ─────────────────────────────────────────────────────────────
d1_e50  = request.security(syminfo.tickerid, "D", ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
d1_e200 = request.security(syminfo.tickerid, "D", ta.ema(close, 200), lookahead=barmerge.lookahead_off)
d1_c    = request.security(syminfo.tickerid, "D", close,              lookahead=barmerge.lookahead_off)
d1_bull = d1_c > d1_e50  and d1_e50  > d1_e200
d1_bear = d1_c < d1_e50  and d1_e50  < d1_e200

h4_e50  = request.security(syminfo.tickerid, "240", ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
h4_e200 = request.security(syminfo.tickerid, "240", ta.ema(close, 200), lookahead=barmerge.lookahead_off)
h4_c    = request.security(syminfo.tickerid, "240", close,              lookahead=barmerge.lookahead_off)
h4_bull = h4_c > h4_e50  and h4_e50  > h4_e200
h4_bear = h4_c < h4_e50  and h4_e50  < h4_e200

// Trend filters (optional)
trend_ok_buy  = (not req_d1 or d1_bull) and (not req_h4 or h4_bull)
trend_ok_sell = (not req_d1 or d1_bear) and (not req_h4 or h4_bear)

// ── SESSION ───────────────────────────────────────────────────────────────────
h = hour(time, "UTC")
in_session = not sess_f or ((h >= 7 and h < 11) or (h >= 12 and h < 16))

// ── CANDLE BASICS ─────────────────────────────────────────────────────────────
body    = math.abs(close - open)
up_wick = high - math.max(close, open)
dn_wick = math.min(close, open) - low
bull_c  = close > open
bear_c  = close < open

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 1 — M2B / M2S  (Two-legged pullback to 20 EMA)
// Highest WR setup: EMA rising → price pulls back to EMA → bounces (2 legs)
// ══════════════════════════════════════════════════════════════════════════════
ema_rising  = ema20 > ema20[8] and ema20[8] > ema20[16]
ema_falling = ema20 < ema20[8] and ema20[8] < ema20[16]

// Price touched EMA zone in last 10 bars (pullback happened)
touched_bull = ta.lowest(low, 10) <= ema20[5] + atr14 * 0.6
touched_bear = ta.highest(high,10) >= ema20[5] - atr14 * 0.6

// Now price back above/below EMA — bounce confirmed
m2b_sig = ema_rising  and close > ema20 and close > close[1] and touched_bull and bull_c and rsi14 > 40 and rsi14 < 65
m2s_sig = ema_falling and close < ema20 and close < close[1] and touched_bear and bear_c and rsi14 < 60 and rsi14 > 35

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 2 — Pin Bar at EMA21 / Support / Resistance
// ══════════════════════════════════════════════════════════════════════════════
// Pin bar
bull_pin = dn_wick > body * 2.2 and dn_wick > up_wick * 2.0 and body > atr14 * 0.04
bear_pin = up_wick > body * 2.2 and up_wick > dn_wick * 2.0 and body > atr14 * 0.04

// At key level (EMA21 or pivot)
at_ema_bull = math.abs(low - ema21) < atr14 * 0.5
at_ema_bear = math.abs(high - ema21) < atr14 * 0.5

ph = ta.pivothigh(high, 5, 5)
pl = ta.pivotlow(low, 5, 5)
var float r_level = na
var float s_level = na
if not na(ph) then r_level := ph
if not na(pl) then s_level := pl

at_support = not na(s_level) and low <= s_level + atr14 * 0.4 and low >= s_level - atr14 * 0.3
at_resist  = not na(r_level) and high >= r_level - atr14 * 0.4 and high <= r_level + atr14 * 0.3

pin_buy  = bull_pin and (at_ema_bull or at_support)
pin_sell = bear_pin and (at_ema_bear or at_resist)

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 3 — Inside Bar False Breakout (IB FBO)
// Mother bar → Inside bar forms → breaks one side → reverses = trapped traders
// ══════════════════════════════════════════════════════════════════════════════
ib_formed = high[1] < high[2] and low[1] > low[2]   // inside bar was bar[1]
// Bullish FBO: broke below mother low (faked out bears) then closed back above
ib_fbo_bull = ib_formed and low  < low[2]  and close > low[2]  and close > open
// Bearish FBO: broke above mother high (faked out bulls) then closed back below
ib_fbo_bear = ib_formed and high > high[2] and close < high[2] and close < open

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 4 — Engulfing Bar at Trend + Level
// ══════════════════════════════════════════════════════════════════════════════
bull_eng = close[1] < open[1] and close > open and close > open[1] and open < close[1] and body > atr14 * 0.3
bear_eng = close[1] > open[1] and close < open and close < open[1] and open > close[1] and body > atr14 * 0.3

eng_buy  = bull_eng and (at_support or at_ema_bull) and close > ema50
eng_sell = bear_eng and (at_resist  or at_ema_bear) and close < ema50

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 5 — 3-Bar Reversal
// ══════════════════════════════════════════════════════════════════════════════
no_ob   = not (high[1] > high[2] and low[1] < low[2])
br3_buy  = close[2] < open[2] and low[1]  < low[2]  and no_ob and close > high[2] and body > atr14 * 0.2
br3_sell = close[2] > open[2] and high[1] > high[2] and no_ob and close < low[2]  and body > atr14 * 0.2

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY 6 — Supertrend Flip (simple, clean)
// ══════════════════════════════════════════════════════════════════════════════
st_flip_buy  = st_dir[1] > 0 and st_dir < 0   // flipped bullish
st_flip_sell = st_dir[1] < 0 and st_dir > 0   // flipped bearish

// ── PICK ACTIVE STRATEGY ─────────────────────────────────────────────────────
var bool sig_buy  = false
var bool sig_sell = false

if strat == "M2B_M2S"
    sig_buy  := m2b_sig
    sig_sell := m2s_sig
else if strat == "Pin_Bar_EMA"
    sig_buy  := pin_buy
    sig_sell := pin_sell
else if strat == "IB_FBO"
    sig_buy  := ib_fbo_bull
    sig_sell := ib_fbo_bear
else if strat == "Engulfing_Trend"
    sig_buy  := eng_buy
    sig_sell := eng_sell
else if strat == "3Bar_Reversal"
    sig_buy  := br3_buy
    sig_sell := br3_sell
else if strat == "Supertrend_Only"
    sig_buy  := st_flip_buy  and close > d1_e50
    sig_sell := st_flip_sell and close < d1_e50
else  // All_Combined
    sig_buy  := (m2b_sig or pin_buy or ib_fbo_bull or eng_buy or br3_buy) and not (m2s_sig or pin_sell or ib_fbo_bear or eng_sell or br3_sell)
    sig_sell := (m2s_sig or pin_sell or ib_fbo_bear or eng_sell or br3_sell) and not (m2b_sig or pin_buy or ib_fbo_bull or eng_buy or br3_buy)

// Apply trend + session filters
final_buy  = sig_buy  and trend_ok_buy  and in_session
final_sell = sig_sell and trend_ok_sell and in_session

// ── SL / TP ───────────────────────────────────────────────────────────────────
sl_d = atr14 * sl_atr
tp_d = atr14 * tp_atr

// ── ENTRIES ───────────────────────────────────────────────────────────────────
if final_buy and strategy.position_size <= 0
    strategy.entry("BUY", strategy.long)
    strategy.exit("BX", "BUY", stop=strategy.position_avg_price - sl_d, limit=strategy.position_avg_price + tp_d)

if final_sell and strategy.position_size >= 0
    strategy.entry("SELL", strategy.short)
    strategy.exit("SX", "SELL", stop=strategy.position_avg_price + sl_d, limit=strategy.position_avg_price - tp_d)

// ── PLOTS ─────────────────────────────────────────────────────────────────────
plot(ema20,  "EMA20", color=color.new(color.blue,  20))
plot(ema21,  "EMA21", color=color.new(color.yellow,20))
plot(ema50,  "EMA50", color=color.new(color.orange,20))
plot(ema200, "EMA200",color=color.new(color.red,   10), linewidth=2)
plot(st_line,"ST",    color=st_dir < 0 ? color.new(color.green,50) : color.new(color.red,50))

plotshape(final_buy,  "BUY",  shape.triangleup,   location.belowbar, color.green, size=size.normal, text="BUY")
plotshape(final_sell, "SELL", shape.triangledown, location.abovebar, color.red,   size=size.normal, text="SELL")

bgcolor(d1_bull ? color.new(color.green,96) : d1_bear ? color.new(color.red,96) : na, title="D1 Trend BG")

// ── INFO TABLE ────────────────────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black,70), border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(t,0,0,"Strategy",  text_color=color.gray,  text_size=size.small)
    table.cell(t,1,0, strat,      text_color=color.white, text_size=size.small)
    table.cell(t,0,1,"D1 Trend",  text_color=color.gray,  text_size=size.small)
    table.cell(t,1,1, d1_bull?"▲ BULL":d1_bear?"▼ BEAR":"NEUTRAL", text_color=d1_bull?color.green:d1_bear?color.red:color.gray, text_size=size.small)
    table.cell(t,0,2,"H4 Trend",  text_color=color.gray,  text_size=size.small)
    table.cell(t,1,2, h4_bull?"▲ BULL":h4_bear?"▼ BEAR":"NEUTRAL", text_color=h4_bull?color.green:h4_bear?color.red:color.gray, text_size=size.small)
    table.cell(t,0,3,"Session",   text_color=color.gray,  text_size=size.small)
    table.cell(t,1,3, in_session?"Active 🔥":"Off-Hrs",   text_color=in_session?color.green:color.gray, text_size=size.small)
    table.cell(t,0,4,"Signal",    text_color=color.gray,  text_size=size.small)
    table.cell(t,1,4, final_buy?"BUY ▲":final_sell?"SELL ▼":"—",   text_color=final_buy?color.green:final_sell?color.red:color.gray, text_size=size.small)
    table.cell(t,0,5,"RSI",       text_color=color.gray,  text_size=size.small)
    table.cell(t,1,5, str.tostring(math.round(rsi14,1)),  text_color=rsi14>65?color.red:rsi14<35?color.green:color.gray, text_size=size.small)
